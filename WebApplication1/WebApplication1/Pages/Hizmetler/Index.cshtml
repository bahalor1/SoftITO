@page
@model WebApplication1.Pages.Hizmetler.IndexModel
@{
    ViewData["Title"] = "Hizmetler";
}

<h2>Hizmet Yönetimi</h2>
<a asp-page="Create" class="btn btn-success mb-3">Yeni Hizmet Ekle</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Hizmet Adı</th>
            <th>Kısa Açıklama</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.HizmetListesi)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.HizmetAdi</td>
                <td>@item.KisaAciklama</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>