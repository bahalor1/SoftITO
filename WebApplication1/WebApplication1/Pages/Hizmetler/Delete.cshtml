@page "{id:int}"
@model WebApplication1.Pages.Hizmetler.DeleteModel
@{
    ViewData["Title"] = "Hizmet Sil";
}

<h2>Hizmet Sil</h2>
<h4 class="text-danger">Bu hizmeti silmek istediğinize emin misiniz?</h4>

<div class="card w-50 mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.SilinecekHizmet.HizmetAdi</h5>
        <p class="card-text">@Model.SilinecekHizmet.KisaAciklama</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="SilinecekHizmet.Id" />
    <button type="submit" class="btn btn-danger">Evet, Sil</button>
    <a asp-page="Index" class="btn btn-secondary">İptal</a>
</form>