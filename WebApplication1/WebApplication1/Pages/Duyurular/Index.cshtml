@page
@model WebApplication1.Pages.Duyurular.IndexModel
@{
    ViewData["Title"] = "Duyurular";
}

<h2>Duyuru Yönetimi</h2>
<a asp-page="Create" class="btn btn-success mb-3">Yeni Duyuru Ekle</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Başlık</th>
            <th>İçerik</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.DuyuruListesi)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Baslik</td>
                <td>@item.Icerik</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>