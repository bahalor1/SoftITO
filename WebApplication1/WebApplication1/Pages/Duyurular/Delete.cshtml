@page "{id:int}"
@model WebApplication1.Pages.Duyurular.DeleteModel
@{
    ViewData["Title"] = "Duyuru Sil";
}

<h2>Duyuru Sil</h2>
<h4 class="text-danger">Bu kaydı silmek istediğinize emin misiniz?</h4>

<div class="card w-50 mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.SilinecekDuyuru.Baslik</h5>
        <p class="card-text">@Model.SilinecekDuyuru.Icerik</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="SilinecekDuyuru.Id" />
    <button type="submit" class="btn btn-danger">Evet, Sil</button>
    <a asp-page="Index" class="btn btn-secondary">İptal</a>
</form>