@page "{id:int}"
@model WebApplication1.Pages.Referanslar.DeleteModel
@{
    ViewData["Title"] = "Referans Sil";
}

<h2>Referans Sil</h2>
<h4 class="text-danger">Bu referansı silmek istediğinize emin misiniz?</h4>

<div class="card w-50 mt-3">
    <div class="card-body">
        <h5 class="card-title">@Model.SilinecekReferans.MusteriAdi</h5>
        <p class="card-text">Şirket: @Model.SilinecekReferans.Sirket</p>
    </div>
</div>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="SilinecekReferans.Id" />
    <button type="submit" class="btn btn-danger">Evet, Sil</button>
    <a asp-page="Index" class="btn btn-secondary">İptal</a>
</form>