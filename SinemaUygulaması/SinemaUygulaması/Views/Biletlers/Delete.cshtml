@model SinemaUygulaması.Models.Biletler
@{
    ViewData["Title"] = "Bileti İptal Et";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger shadow-sm text-center p-4 rounded-4" role="alert">
                <h2 class="alert-heading fw-bold"> DİKKAT!</h2>
                <p class="fs-5">Bu bileti silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
                <hr>

                <div class="bg-white text-dark p-3 rounded-3 text-start mb-4 shadow-sm">
                    <p class="mb-1"><strong>Müşteri:</strong> @Model.MusteriAdSoyad</p>
                    <p class="mb-1"><strong>Film:</strong> @Model.Seans?.Film?.FilmAdi</p>
                    <p class="mb-1"><strong>Salon:</strong> @Model.Seans?.SalonAdi</p>
                    <p class="mb-0"><strong>Koltuk No:</strong> <span class="badge bg-danger fs-6">@Model.KoltukNo</span></p>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-lg fw-bold px-5 me-3 shadow-sm">
                        Evet, Bileti İptal Et 
                    </button>
                    <a  asp-action="Index" class="btn btn-secondary btn-lg fw-bold px-4 shadow-sm">
                        Vazgeç
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>