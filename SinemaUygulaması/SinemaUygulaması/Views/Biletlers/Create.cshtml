@model SinemaUygulaması.Models.Biletler

@{
    ViewData["Title"] = "Yeni Bilet Kes";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white text-center py-4 rounded-top-4">
                    <h3 class="mb-0 fw-bold">Yeni Bilet Kes</h3>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="SeansId" class="form-label fw-bold text-secondary">Seans Seçin</label>
                            <select asp-for="SeansId" class="form-select border-2" asp-items="ViewBag.SeansId">
                                <option value="">Seans Seçiniz</option>
                            </select>
                            <span asp-validation-for="SeansId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="MusteriAdSoyad" class="form-label fw-bold text-secondary">Müşteri Ad Soyad</label>
                            <input asp-for="MusteriAdSoyad" class="form-control border-2" placeholder="Örn: Ali Yılmaz" />
                            <span asp-validation-for="MusteriAdSoyad" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="KoltukNo" class="form-label fw-bold text-secondary">Koltuk Numarası</label>
                            <input asp-for="KoltukNo" class="form-control border-2" placeholder="Örn: C4" />
                            <span asp-validation-for="KoltukNo" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-3 mt-5">
                            <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                                Bileti Onayla 
                            </button>
                            <a asp-controller="Home"  asp-action="Index" class="btn btn-outline-secondary fw-bold">
                                İptal ve Listeye Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>