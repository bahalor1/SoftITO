@model KütüphaneUygulaması.Models.Yorum

@{
    ViewData["Title"] = "Delete";
}

<div class="alert alert-danger mt-4">
    <h3> Uyarı: Bu yorumu silmek istediğinize emin misiniz?</h3>
    <p class="mb-0">Bu işlemi onaylarsanız yorum veritabanından kalıcı olarak silinecektir.</p>
</div>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Metin)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Metin)
        </dd>
    </dl>
    <dl class="row">
        <dt class="col-sm-2 fw-bold">
            İlgili Kitap
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Kitap.KitapAdi)
        </dd>
    </dl>
    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger fw-bold"> Evet, Kalıcı Olarak Sil</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
    </form>
</div>
