@model KütüphaneUygulaması.Models.Yorum

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Yorum</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="KitapId" class="control-label fw-bold">İlgili Kitap</label>
                <select asp-for="KitapId" class="form-select" asp-items="ViewBag.KitapId"></select>
                <span asp-validation-for="KitapId" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Metin" class="control-label fw-bold">Yorum Metni</label>
                <textarea asp-for="Metin" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Metin" class="text-danger"></span>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary fw-bold"> Güncelle</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
