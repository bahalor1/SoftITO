@model KütüphaneUygulaması.Models.Yorum

@{
    ViewData["Title"] = "Yeni Yorum Ekle";
}

<h1>Yeni Yorum Ekle</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="KitapId" class="control-label fw-bold">Kitaplar</label>
                <select asp-for="KitapId" class="form-select" asp-items="ViewBag.KitapId">
                    <option value="">Lütfen Kitap Seçin</option>
                </select>
                <span asp-validation-for="KitapId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-4">
                <label asp-for="Metin" class="control-label fw-bold">Yorumunuz</label>
                <textarea asp-for="Metin" class="form-control" rows="4" placeholder="Yorumunuzu buraya yazın..."></textarea>
                <span asp-validation-for="Metin" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success fw-bold"> Kaydet</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
            </div>
        </form>
    </div>
</div>