<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Paneli</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="d-flex">
        <div class="bg-dark text-white p-3 vh-100" style="width: 250px;">
            <h4 class="text-center mt-2">Admin Paneli</h4>
            <hr />
            <div class="d-grid gap-2 mb-4">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm fw-bold">
                    SİTEYE GERİ DÖN
                </a>

            </div>
            <ul class="nav flex-column">
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Kategoriler" asp-action="Index">Kategoriler</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Yazarlar" asp-action="Index">Yazarlar</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Kitaplar" asp-action="Index">Kitaplar</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Yorumlar" asp-action="Index">Yorumlar</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Raporlar" asp-action="Index"> Raporlar</a>
                </li>
            </ul>
        </div>

        <div class="p-4 w-100 bg-light">
            @RenderBody()
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>