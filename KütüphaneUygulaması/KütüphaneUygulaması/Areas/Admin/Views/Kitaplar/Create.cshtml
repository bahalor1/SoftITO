@model KütüphaneUygulaması.Models.Kitap

@{
    ViewData["Title"] = "Yeni Kitap Ekle";
}

<h1>Yeni Kitap Ekle</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="KitapAdi" class="control-label fw-bold">Kitap Adı</label>
                <input asp-for="KitapAdi" class="form-control" placeholder="Kitabın adını girin..." />
                <span asp-validation-for="KitapAdi" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="YazarId" class="control-label fw-bold">Yazar</label>
                <select asp-for="YazarId" class="form-select" asp-items="ViewBag.YazarId">
                    <option value="">Lütfen Yazar Seçin</option>
                </select>
                <span asp-validation-for="YazarId" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="KategoriId" class="control-label fw-bold">Kategori</label>
                <select asp-for="KategoriId" class="form-select" asp-items="ViewBag.KategoriId">
                    <option value="">Lütfen Kategori Seçin</option>
                </select>
                <span asp-validation-for="KategoriId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value=" Kaydet" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}