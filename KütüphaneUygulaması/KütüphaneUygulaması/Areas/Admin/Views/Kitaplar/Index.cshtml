@model IEnumerable<KütüphaneUygulaması.Models.Kitap>

@{
    ViewData["Title"] = "Index";
}

<h1>KİTAPLAR</h1>

<p>
    <a asp-action="Create" class="btn btn-sm btn-warning">Kitap Ekle</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th> Kitap Adı </th>
            <th> Kategori </th>
            <th> Yazar</th>
            <th class="text-end">İşlemler</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td class="align-middle">@item.KitapAdi</td>
            <td class="align-middle">@item.Kategori.KategoriAdi</td> 
            <td class="align-middle">@item.Yazar.AdSoyad</td>
            <td class="text-end"> <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Düzenle</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detaylar</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Sil</a>
            </td>
        </tr>
}
    </tbody>
</table>
