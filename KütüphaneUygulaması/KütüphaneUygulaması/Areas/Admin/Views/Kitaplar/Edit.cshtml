@model KütüphaneUygulaması.Models.Kitap

@{
    ViewData["Title"] = "Kitap Düzenle";
}

<h1>Kitap Düzenle</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="KitapAdi" class="control-label fw-bold">Kitap Adı</label>
                <input asp-for="KitapAdi" class="form-control" />
                <span asp-validation-for="KitapAdi" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="YazarId" class="control-label fw-bold">Yazar</label>
                <select asp-for="YazarId" class="form-select" asp-items="ViewBag.YazarId"></select>
                <span asp-validation-for="YazarId" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="KategoriId" class="control-label fw-bold">Kategori</label>
                <select asp-for="KategoriId" class="form-select" asp-items="ViewBag.KategoriId"></select>
                <span asp-validation-for="KategoriId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="💾 Güncelle" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}