@model KütüphaneUygulaması.Models.Kategori

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<h1>Kategori Oluştur</h1>

<h4>Kategori</h4>
<hr />
<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="KategoriAdi" class="control-label fw-bold">Kategori Adı</label>
                <input asp-for="KategoriAdi" class="form-control" placeholder="Örn: Roman, Tarih, Bilim Kurgu..." />
                <span asp-validation-for="KategoriAdi" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-success fw-bold">Kaydet</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">İptal ve Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
